# Firebase 프로젝트 설정 (Firebase 콘솔 > 프로젝트 설정 > 일반 > 웹 앱에서 확인)
# 이 파일은 값 없이 키 이름만 저장소에 남긴다. 실제 값은 .env 파일에 넣고, .env는 절대 커밋하지 않는다.
# Expo는 EXPO_PUBLIC_ 접두사가 붙은 변수만 클라이언트 번들에 노출한다.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# 도움 요청에 함께 전송할 병실 정보 (선택 사항, 비워두면 병실 정보 없이 전송)
EXPO_PUBLIC_ROOM_INFO=

# 보호자 대시보드 진입용 PIN (환자용 화면과 구분하기 위한 용도일 뿐 진짜 보안 경계는 아님)
EXPO_PUBLIC_CAREGIVER_PIN=
